# Application Environment
# 'development' for staging, 'production' for live deployments
APP_ENV=development
APP_NAME=TaxSafar
BASE_URL=http://localhost/ca_inquiry_system/public

# Database Configuration
# Default XAMPP settings: User='root', Pass=''
DB_HOST=localhost
DB_NAME=taxsafar_db
DB_USER=root
DB_PASS=
# Ensure this matches your MySQL server port if it isn't 3306
DB_PORT=3306

# Administration Fallback
# ADMIN_EMAIL=admin@taxsafar.com
# ADMIN_PASS=Admin@1234
